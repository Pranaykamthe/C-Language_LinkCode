#include <stdio.h>

int main() {

    int no;
    printf("Enter a number to check divisibility: ");
    scanf("%d", &no);
    if(no % 2 == 0) {
        printf("%d is divisible by 2.\n", no);
    } 
    else if(no % 3 == 0) {
        printf("%d is divisible by 3.\n", no);
    }
    else if(no % 5 == 0) {
        printf("%d is divisible by 5.\n", no);
    }
    else {
        printf("%d is not divisible by 2, 3, or 5.\n", no);
    }

    
    return 0;
}